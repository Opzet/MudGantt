<MudButtonGroup Variant="Variant.Outlined" Color="@Color">
    <MudButton StartIcon="@Icons.Material.Filled.ZoomIn" OnClick="OnZoomIn">Zoom In</MudButton>
    <MudButton StartIcon="@Icons.Material.Filled.ZoomOut" OnClick="OnZoomOut">Zoom Out</MudButton>
    <MudButton StartIcon="@Icons.Material.Filled.FitScreen" OnClick="OnReset">Reset</MudButton>
</MudButtonGroup>

@code {
    [Parameter] public Color Color { get; set; } = Color.Primary;
    [Parameter] public EventCallback OnZoomIn { get; set; }
    [Parameter] public EventCallback OnZoomOut { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }
}
