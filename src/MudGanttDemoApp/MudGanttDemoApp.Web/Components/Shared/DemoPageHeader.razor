<MudPaper Elevation="0" Class="page-header-card">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
        <MudStack Spacing="0">
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                @if (!string.IsNullOrWhiteSpace(Icon))
                {
                    <MudIcon Icon="@Icon" />
                }
                <MudText Typo="@TitleTypo">@Title</MudText>
            </MudStack>
            @if (!string.IsNullOrWhiteSpace(Description))
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Description</MudText>
            }
        </MudStack>

        @if (Actions is not null)
        {
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                @Actions
            </MudStack>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public Typo TitleTypo { get; set; } = Typo.h4;
    [Parameter] public RenderFragment? Actions { get; set; }
}
