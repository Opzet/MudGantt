@page "/sample/calendar"

<PageTitle>Calendar Planning Example</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudStack Spacing="3">
        <div>
            <MudText Typo="Typo.h4">Planning calendar</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Month-style planning surface for customer milestones, procurement, installs, and reviews.</MudText>
        </div>

        <MudPaper Class="pa-4" Elevation="1">
            <MudCalendar T="CalendarExampleItem" Items="_items" />
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h6" Class="mb-2">Upcoming milestones</MudText>
            <MudSimpleTable>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Activity</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _items.OrderBy(x => x.Start).Take(8))
                    {
                        <tr>
                            <td>@item.Start.ToString("dd MMM yyyy HH:mm")</td>
                            <td>@item.Text</td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    private readonly IReadOnlyList<CalendarExampleItem> _items =
    [
        new CalendarExampleItem { Start = PlanningDate(0, 9), Text = "Client A kickoff" },
        new CalendarExampleItem { Start = PlanningDate(2, 13), Text = "Steel delivery" },
        new CalendarExampleItem { Start = PlanningDate(3, 8), Text = "Machine calibration" },
        new CalendarExampleItem { Start = PlanningDate(6, 15, 30), Text = "Customer design signoff" },
        new CalendarExampleItem { Start = PlanningDate(8, 7, 30), Text = "Factory maintenance window" },
        new CalendarExampleItem { Start = PlanningDate(10, 10), Text = "Client B FAT" },
        new CalendarExampleItem { Start = PlanningDate(13, 14), Text = "Procurement review" },
        new CalendarExampleItem { Start = PlanningDate(17, 9), Text = "Line 2 installation" },
        new CalendarExampleItem { Start = PlanningDate(21, 11), Text = "CNC run approval" },
        new CalendarExampleItem { Start = PlanningDate(26, 16), Text = "Executive schedule review" }
    ];

    private static DateTime PlanningDate(int dayOffset, int hour, int minute = 0) =>
        DateTime.Today.AddDays(dayOffset).AddHours(hour).AddMinutes(minute);
}
