@page "/sample/transparency"
@using MudGanttDemoApp.Web.ManufacturingApi
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Manufacturing Transparency</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <div>
                <MudText Typo="Typo.h4">Manufacturing transparency dashboard</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Client-visible and production-visible summary of progress, risk, overload, and holiday windows.</MudText>
            </div>
            <MudSelect T="string" Label="Client" Value="@_selectedClient" ValueChanged="OnClientChanged" Style="min-width:260px">
                <MudSelectItem T="string" Value="@AllClients">All clients</MudSelectItem>
                @foreach (var client in _dataset?.Clients ?? [])
                {
                    <MudSelectItem T="string" Value="@client">@client</MudSelectItem>
                }
            </MudSelect>
        </MudStack>

        @if (_dataset is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.subtitle2">Visible jobs</MudText><MudText Typo="Typo.h4">@FilteredJobs.Count</MudText></MudPaper></MudItem>
                <MudItem xs="12" md="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.subtitle2">Weighted progress</MudText><MudText Typo="Typo.h4">@WeightedProgress%</MudText></MudPaper></MudItem>
                <MudItem xs="12" md="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.subtitle2">Conflicts</MudText><MudText Typo="Typo.h4">@FilteredJobs.Count(x => x.HasConflict)</MudText></MudPaper></MudItem>
                <MudItem xs="12" md="3"><MudPaper Class="pa-3" Elevation="1"><MudText Typo="Typo.subtitle2">Overloaded machines</MudText><MudText Typo="Typo.h4">@VisibleResources.Count(x => x.IsOverloaded)</MudText></MudPaper></MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="12" lg="7">
                    <MudPaper Class="pa-4" Elevation="1" Style="height:360px;">
                        <MudText Typo="Typo.h6" Class="mb-2">Client delivery timeline</MudText>
                        <MudGanttChart Tasks="ChartTasks"
                                       Events="_dataset.Holidays"
                                       Dense="true"
                                       Size="Size.Small"
                                       ReadOnly="true"
                                       Color="Color.Success"
                                       Variant="Variant.Outlined" />
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" lg="5">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-2">At-risk jobs</MudText>
                        @foreach (var job in FilteredJobs.Where(x => x.HasConflict || x.DelayHours > 0 || x.IsCritical).OrderByDescending(x => x.HasConflict).ThenByDescending(x => x.DelayHours).Take(10))
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                                <div>
                                    <MudText Typo="Typo.body2">@job.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@job.Client · @job.Machine · @job.Worker</MudText>
                                </div>
                                <MudStack Row="true" Spacing="1">
                                    @if (job.IsCritical)
                                    {
                                        <MudChip T="string" Color="Color.Error" Size="Size.Small">Critical</MudChip>
                                    }
                                    @if (job.HasConflict)
                                    {
                                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Conflict</MudChip>
                                    }
                                    @if (job.DelayHours > 0)
                                    {
                                        <MudChip T="string" Color="Color.Info" Size="Size.Small">@job.DelayHours h delay</MudChip>
                                    }
                                </MudStack>
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-2">Machine capacity summary</MudText>
                        <MudSimpleTable>
                            <thead>
                                <tr>
                                    <th>Machine</th>
                                    <th>Utilization</th>
                                    <th>Conflicts</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var resource in VisibleResources.OrderByDescending(x => x.IsOverloaded).ThenByDescending(x => x.UtilizationPercent).Take(10))
                                {
                                    <tr>
                                        <td>@resource.Machine</td>
                                        <td>@resource.UtilizationPercent%</td>
                                        <td>@resource.ConflictCount</td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" lg="6">
                    <MudPaper Class="pa-4" Elevation="1">
                        <MudText Typo="Typo.h6" Class="mb-2">Calendar windows</MudText>
                        @foreach (var holiday in _dataset.Holidays)
                        {
                            <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-2">
                                <MudText Typo="Typo.body2">@holiday.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@holiday.Date.ToString("dd MMM HH:mm") - @holiday.EndDate?.ToString("dd MMM HH:mm")</MudText>
                            </MudStack>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </MudStack>
</MudContainer>

@code {
    private const string AllClients = ManufacturingQueries.AllClients;
    private HttpClient _http = default!;
    private ManufacturingDatasetDto? _dataset;
    private string _selectedClient = AllClients;

    protected override async Task OnInitializedAsync()
    {
        _http = HttpClientFactory.CreateClient();
        _http.BaseAddress = new Uri(NavigationManager.BaseUri);
        _dataset = await _http.GetFromJsonAsync<ManufacturingDatasetDto>("api/manufacturing/dataset?jobs=500");
    }

    private ManufacturingFilterState FilterState => new() { Client = _selectedClient, Machine = ManufacturingQueries.AllMachines };
    private IReadOnlyList<ManufacturingJobDto> FilteredJobs => ManufacturingQueries.FilterJobs(_dataset?.Jobs ?? [], FilterState);
    private IReadOnlyList<ManufacturingResourceDto> VisibleResources => ManufacturingQueries.VisibleResourcesForJobs(_dataset?.Resources ?? [], FilteredJobs);
    private string WeightedProgress => (GanttTaskAnalysis.CalculateWeightedProgress(ChartTasks) * 100).ToString("0.0");

    private IReadOnlyList<MudGanttTask> ChartTasks => FilteredJobs.Take(80).Select(ManufacturingTaskMapper.ToClientJobTask).ToList();

    private void OnClientChanged(string client) => _selectedClient = client;
}
