@page "/sample/calendar-machines"

<PageTitle>Machine Calendars</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-4">
    <MudStack Spacing="3">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <div>
                <MudText Typo="Typo.h4">Machine and resource calendars</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Machine-specific capacity calendar with non-working day entries and maintenance windows.</MudText>
            </div>
            <MudSelect T="string" Label="Machine" Value="@_selectedMachine" ValueChanged="OnMachineChanged" Style="min-width:260px">
                @foreach (var machine in _machines)
                {
                    <MudSelectItem T="string" Value="@machine">@machine</MudSelectItem>
                }
            </MudSelect>
        </MudStack>

        <MudGrid>
            <MudItem xs="12" lg="8">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudCalendar T="CalendarExampleItem" Items="FilteredItems" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" lg="4">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.h6" Class="mb-2">Machine load</MudText>
                    <MudSimpleTable>
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Entries</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var day in FilteredItems.Where(x => !x.AllDay).GroupBy(x => x.Start.Date).OrderBy(x => x.Key))
                            {
                                <tr>
                                    <td>@day.Key.ToString("dd MMM")</td>
                                    <td>@day.Count()</td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudStack>
</MudContainer>

@code {
    private readonly IReadOnlyList<string> _machines = ["CNC-01", "CNC-02", "Laser-01", "Paint Booth"];
    private string _selectedMachine = "CNC-01";

    private readonly IReadOnlyList<CalendarExampleItem> _items =
    [
        new CalendarExampleItem { Start = MachineDate(0, 6), Text = "Job 2501 · Client A", Machine = "CNC-01", JobId = "2501", Client = "Client A", Category = "Production" },
        new CalendarExampleItem { Start = MachineDate(0, 14), Text = "Maintenance", Machine = "CNC-01", Category = "Maintenance" },
        new CalendarExampleItem { Start = MachineDate(1, 7), Text = "Job 2508 · Client B", Machine = "CNC-01", JobId = "2508", Client = "Client B", Category = "Production" },
        new CalendarExampleItem { Start = MachineDate(2, 8), Text = "Job 2514 · Client C", Machine = "CNC-02", JobId = "2514", Client = "Client C", Category = "Production" },
        new CalendarExampleItem { Start = MachineDate(2, 13), Text = "Job 2515 · Client A", Machine = "CNC-02", JobId = "2515", Client = "Client A", Category = "Production" },
        new CalendarExampleItem { Start = MachineDate(3, 9), Text = "Nest optimization", Machine = "Laser-01", Category = "Setup" },
        new CalendarExampleItem { Start = MachineDate(3, 11), Text = "Job 2520 · Client D", Machine = "Laser-01", JobId = "2520", Client = "Client D", Category = "Production" },
        new CalendarExampleItem { Start = MachineDate(4, 10), Text = "Batch coating · Client B", Machine = "Paint Booth", JobId = "2524", Client = "Client B", Category = "Production" },
        new CalendarExampleItem { Start = MachineDate(5), Text = "Non-working day", Machine = "CNC-01", AllDay = true, Category = "Non-working" },
        new CalendarExampleItem { Start = MachineDate(6), Text = "Non-working day", Machine = "CNC-01", AllDay = true, Category = "Non-working" },
        new CalendarExampleItem { Start = MachineDate(5), Text = "Non-working day", Machine = "CNC-02", AllDay = true, Category = "Non-working" },
        new CalendarExampleItem { Start = MachineDate(6), Text = "Non-working day", Machine = "CNC-02", AllDay = true, Category = "Non-working" },
        new CalendarExampleItem { Start = MachineDate(5), Text = "Non-working day", Machine = "Laser-01", AllDay = true, Category = "Non-working" },
        new CalendarExampleItem { Start = MachineDate(6), Text = "Non-working day", Machine = "Laser-01", AllDay = true, Category = "Non-working" },
        new CalendarExampleItem { Start = MachineDate(5), Text = "Non-working day", Machine = "Paint Booth", AllDay = true, Category = "Non-working" },
        new CalendarExampleItem { Start = MachineDate(6), Text = "Non-working day", Machine = "Paint Booth", AllDay = true, Category = "Non-working" }
    ];

    private IEnumerable<CalendarExampleItem> FilteredItems => _items.Where(x => x.Machine == _selectedMachine);

    private void OnMachineChanged(string machine) => _selectedMachine = machine;

    private static DateTime MachineDate(int dayOffset, int hour = 0, int minute = 0) =>
        DateTime.Today.AddDays(dayOffset).AddHours(hour).AddMinutes(minute);
}
