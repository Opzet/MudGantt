<MudPaper Class="pa-4 page-toolbar-card" Elevation="2">
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
        <MudTextField Value="@Search"
                      ValueChanged="SearchChanged"
                      Placeholder="Search tasks"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" />
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="OnAddTask">
            Add Task
        </MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Sync"
                   Variant="Variant.Outlined"
                   Color="Color.Info"
                   OnClick="OnReload"
                   Disabled="IsBusy">
            Reload
        </MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Delete"
                   Variant="Variant.Outlined"
                   Color="Color.Error"
                   OnClick="OnDeleteSelected"
                   Disabled="@(DisableDelete || IsBusy)">
            Delete Task
        </MudButton>
        <MudSpacer />
        <GanttZoomControls OnZoomIn="OnZoomIn" OnZoomOut="OnZoomOut" OnReset="OnReset" />
        <MudButton Variant="Variant.Text"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.ViewSidebar"
                   OnClick="OnToggleTaskList">
            @(CollapseTaskList ? "Show Task List" : "Collapse Task List")
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Badge"
                   OnClick="OnToggleAttendanceMode">
            @(AttendanceMode ? "Standard View" : "Attendance View")
        </MudButton>
        <MudIconButton Icon="@(ShowSettings ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.Settings)"
                       Color="Color.Primary"
                       OnClick="OnToggleSettings"
                       Title="Toggle Settings" />
    </MudStack>
</MudPaper>

@code {
    [Parameter] public string Search { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SearchChanged { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public bool DisableDelete { get; set; }
    [Parameter] public bool CollapseTaskList { get; set; }
    [Parameter] public bool AttendanceMode { get; set; }
    [Parameter] public bool ShowSettings { get; set; }
    [Parameter] public EventCallback OnAddTask { get; set; }
    [Parameter] public EventCallback OnReload { get; set; }
    [Parameter] public EventCallback OnDeleteSelected { get; set; }
    [Parameter] public EventCallback OnZoomIn { get; set; }
    [Parameter] public EventCallback OnZoomOut { get; set; }
    [Parameter] public EventCallback OnReset { get; set; }
    [Parameter] public EventCallback OnToggleTaskList { get; set; }
    [Parameter] public EventCallback OnToggleAttendanceMode { get; set; }
    [Parameter] public EventCallback OnToggleSettings { get; set; }
}
