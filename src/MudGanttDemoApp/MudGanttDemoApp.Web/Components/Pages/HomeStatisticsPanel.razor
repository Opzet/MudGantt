@using MudGantt

<MudPaper Class="pa-4 mt-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-3">
        <MudIcon Icon="@Icons.Material.Filled.Analytics" Class="mr-2" />
        Project Statistics
    </MudText>
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MetricSummaryCard Label="Total Tasks" Value="@Tasks.Count.ToString()" Color="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MetricSummaryCard Label="Completed Tasks" Value="@Tasks.Count(t => (t.Progress ?? 0) >= 1.0).ToString()" Color="Color.Success" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MetricSummaryCard Label="In Progress" Value="@Tasks.Count(t => (t.Progress ?? 0) > 0 && (t.Progress ?? 0) < 1.0).ToString()" Color="Color.Info" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MetricSummaryCard Label="Overall Progress" Value="@HomePageSupport.GetOverallProgress(Tasks)" Color="Color.Warning" />
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<MudGanttTask> Tasks { get; set; } = [];
}
