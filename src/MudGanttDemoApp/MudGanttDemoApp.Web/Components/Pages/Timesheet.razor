@page "/timesheet"

<PageTitle>Time Entry — MudGantt</PageTitle>

<div class="pm-timesheet-page">

    <!-- ══ TOOLBAR ═════════════════════════════════════════════════════════ -->
    <div class="pm-timesheet-toolbar">
        <MudButton StartIcon="@Icons.Material.Filled.Add"
                   Variant="Variant.Outlined" Color="Color.Success"
                   Size="Size.Small" OnClick="AddTask">Add Tasks</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.ContentCopy"
                   Variant="Variant.Outlined" Color="Color.Default"
                   Size="Size.Small" OnClick="CopyLastWeek">Copy Last Week</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.AutoAwesome"
                   Variant="Variant.Outlined" Color="Color.Default"
                   Size="Size.Small" OnClick="AutoFill">Auto-Fill</MudButton>

        <div class="pm-toolbar-sep"></div>

        <MudTextField @bind-Value="_assignee"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ArrowDropDown"
                      Style="width:180px;" />

        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                       Size="Size.Small" OnClick="PreviousWeek" />
        <MudText Typo="Typo.body2" Style="min-width:90px; text-align:center;">
            @_weekStart.ToString("M/d/yyyy")
        </MudText>
        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                       Size="Size.Small" OnClick="NextWeek" />

        <MudSpacer />

        <MudButton Variant="Variant.Filled" Color="Color.Success"
                   Size="Size.Small" OnClick="Save">Save</MudButton>
    </div>

    <!-- ══ TIMESHEET GRID ══════════════════════════════════════════════════ -->
    <div class="pm-timesheet-body">
        <table class="pm-timesheet-table">
            <thead>
                <tr>
                    <th style="width:160px;">PROJECT ↕</th>
                    <th style="min-width:200px;">TASK</th>
                    @foreach (var day in WeekDays)
                    {
                        <th style="width:72px; text-align:center;">
                            <div>@day.ToString("ddd")</div>
                            <div style="font-size:11px; font-weight:400;">@day.ToString("MMM d")</div>
                        </th>
                    }
                    <th style="width:64px; text-align:center;">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in _entries)
                {
                    <tr>
                        <td style="font-size:12px; color:var(--mud-palette-text-secondary);">@entry.Project</td>
                        <td>@entry.Task</td>
                        @for (int i = 0; i < 5; i++)
                        {
                            var idx = i;
                            <td style="text-align:center; padding:4px;">
                                <input type="number"
                                       class="pm-timesheet-input @(entry.Hours[idx] > 0 ? "pm-ts-filled" : "")"
                                       min="0" max="24"
                                       value="@entry.Hours[idx]"
                                       @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) entry.Hours[idx] = Math.Clamp(v, 0, 24); }" />
                            </td>
                        }
                        <td class="pm-timesheet-total" style="text-align:center;">@entry.Total</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="pm-timesheet-footer">
                    <td colspan="2" style="padding: 8px 12px;">Totals</td>
                    @for (int i = 0; i < 5; i++)
                    {
                        var idx = i;
                        <td style="text-align:center; padding:8px 4px;">@DayTotal(idx)</td>
                    }
                    <td style="text-align:center; font-weight:700;">@GrandTotal</td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
