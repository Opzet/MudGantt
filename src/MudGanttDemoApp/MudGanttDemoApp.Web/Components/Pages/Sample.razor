@page "/sample"

<PageTitle>Gantt Examples</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    <MudStack Spacing="3">
        <div>
            <MudText Typo="Typo.h3">Gantt examples</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Browse focused examples for planning, dependencies, operations, and attendance-style layouts.</MudText>
        </div>

        <MudGrid>
            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Manufacturing flow</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Linked top/bottom Gantt view for client jobs and machine-worker execution flow.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/manufacturing-flow" Variant="Variant.Filled" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Advanced roster planner</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Rotation planning concepts adapted to the current scheduler resources and shift preview workflow.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="roster/advanced" Variant="Variant.Filled" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Project health dashboard</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Burndown, risk scoring, and manufacturing delivery health based on current demo data.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="project-health" Variant="Variant.Filled" Color="Color.Info">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Portfolio planning</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Cross-client rollup timeline for program and plant-level planning.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/portfolio" Variant="Variant.Filled" Color="Color.Tertiary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Capability matrix</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Implemented feature matrix, verification rubric, and roadmap view.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/capability-matrix" Variant="Variant.Filled" Color="Color.Secondary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Feedback center</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Capture bugs and structured Copilot feedback persisted as JSON.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/feedback" Variant="Variant.Filled" Color="Color.Warning">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Client portal</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Client-friendly progress, milestones, and at-risk delivery transparency.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/client-portal" Variant="Variant.Filled" Color="Color.Success">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Reports and exports</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">CSV exports and print/PDF-ready reporting links for internal and client use.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/reports" Variant="Variant.Filled" Color="Color.Info">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Transparency dashboard</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Client and production reporting dashboard for HMLV manufacturing transparency.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/transparency" Variant="Variant.Filled" Color="Color.Success">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Basic project plan</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Progress, milestones, and zoom controls for a simple roadmap.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/basic" Variant="Variant.Filled" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Critical path + baseline</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Baseline comparison, critical path emphasis, and non-working day highlighting.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/critical-path" Variant="Variant.Filled" Color="Color.Error">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Dependencies</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">See task links and sequencing in a delivery pipeline example.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/dependencies" Variant="Variant.Filled" Color="Color.Secondary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Scheduler workbench</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Tasks, resources, assignments, and working calendar in one planning experience.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/scheduler" Variant="Variant.Filled" Color="Color.Tertiary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Operations board</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Dense, read-only scheduling for support lanes and shift windows.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/operations" Variant="Variant.Filled" Color="Color.Info">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Attendance view</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Employee-style rows with in/out times and hourly zoom.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="attendance" Variant="Variant.Filled" Color="Color.Success">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Planning calendar</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Heron.MudCalendar example for milestones, planning meetings, and delivery checkpoints.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/calendar" Variant="Variant.Filled" Color="Color.Warning">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Production calendar</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Plant, CNC, and client booking calendar view for production scheduling scenarios.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/calendar-production" Variant="Variant.Filled" Color="Color.Error">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Machine calendars</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Resource-specific calendar view for CNC, laser, and paint booth scheduling.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/calendar-machines" Variant="Variant.Filled" Color="Color.Primary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Client / job calendar</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Grouped customer jobs with calendar and expandable client summaries.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/calendar-clients" Variant="Variant.Filled" Color="Color.Secondary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Gantt + Calendar sync</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Side-by-side synchronized planning with shared filters across both views.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/gantt-calendar-sync" Variant="Variant.Filled" Color="Color.Tertiary">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Resource utilization</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Histogram-style machine utilization dashboard generated from manufacturing jobs.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/resource-utilization" Variant="Variant.Filled" Color="Color.Info">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Undo / redo edits</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Editable task chart with working undo and redo history for schedule changes.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/undo-redo" Variant="Variant.Filled" Color="Color.Warning">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" lg="4">
                <MudCard>
                    <MudCardContent>
                        <MudText Typo="Typo.h6">Large dataset</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Generated 1000 and 2500 job manufacturing datasets for scale testing.</MudText>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="sample/large-dataset" Variant="Variant.Filled" Color="Color.Error">Open</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudStack>
</MudContainer>
