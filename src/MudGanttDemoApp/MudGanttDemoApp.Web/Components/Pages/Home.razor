@page "/"

@using MudGanttDemoApp.Web.GanttApi
@inject ISnackbar snackbar
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>MudGantt - Task List Demo</PageTitle>

<MudThemeProvider IsDarkMode="@_darkMode" />

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
    
    <DemoPageHeader Title="Gantt Chart with Synchronised Task List"
                    Description="Real-time task list and inline editing across a synchronized Gantt and details workflow."
                    Icon="@Icons.Material.Filled.CalendarMonth"
                    TitleTypo="Typo.h3" />

    <HomeToolbar Search="_search"
                 SearchChanged="@(value => _search = value)"
                 IsBusy="_isBusy"
                 DisableDelete="@(_selectedTask is null)"
                 CollapseTaskList="_collapseTaskList"
                 AttendanceMode="_attendanceMode"
                 ShowSettings="_showSettings"
                 OnAddTask="AddNewTaskAsync"
                 OnReload="ReloadTasksAsync"
                 OnDeleteSelected="DeleteSelectedTaskAsync"
                 OnZoomIn="ZoomIn"
                 OnZoomOut="ZoomOut"
                 OnReset="ResetZoom"
                 OnToggleTaskList="ToggleTaskList"
                 OnToggleAttendanceMode="ToggleAttendanceMode"
                 OnToggleSettings="ToggleSettings" />

    <!-- Settings Panel (Collapsible) -->
    <MudCollapse Expanded="@_showSettings">
        <HomeSettingsPanel Color="_color"
                           ColorChanged="@(value => _color = value)"
                           Variant="_variant"
                           VariantChanged="@(value => _variant = value)"
                           Size="_size"
                           SizeChanged="@(value => _size = value)"
                           ReadOnly="_readOnly"
                           ReadOnlyChanged="@(value => _readOnly = value)"
                           Dense="_dense"
                           DenseChanged="@(value => _dense = value)"
                           DarkMode="_darkMode"
                           DarkModeChanged="@(value => _darkMode = value)"
                           OnAssignColors="AssignColors"
                           OnClearColors="ClearColors" />
    </MudCollapse>

    <!-- Main Split View: Task List + Gantt Chart -->
    <MudPaper Elevation="3" Class="gantt-split-surface">
        <MudStack Row Class="gantt-split-stack">
            
            <!-- Task List Panel -->
            @if (!_collapseTaskList)
            {
                <HomeTaskListPanel Tasks="FilteredTasks.ToList()"
                                   SelectedTask="_selectedTask"
                                   AttendanceMode="_attendanceMode"
                                   PanelStyle="@TaskListPanelStyle"
                                   OnSelectTask="SelectTask"
                                   OnEditTask="EditTaskDialog" />
            }

            <!-- Gantt Chart Panel -->
            <MudPaper Elevation="0" Class="flex-grow-1 gantt-chart-panel">
                <MudGanttChart @ref="_mudGanttChart"
                               TaskClicked="OnTaskClicked"
                               @bind-Tasks="@_tasks" 
                               Events="@_events" 
                               Color="@_color" 
                               Variant="@_variant" 
                               ReadOnly="@_readOnly" 
                               Dense="@_dense" 
                               Size="@_size"
                               TaskDatesChanged="OnTaskDatesChanged"
                               TaskProgressChanged="OnTaskProgressChanged">

                    <TaskContextMenu>
                        <MudMenuItem Icon="@Icons.Material.Filled.ZoomIn" OnClick="ZoomIn">Zoom in</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ZoomOut" OnClick="ZoomOut">Zoom out</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.FitScreen" OnClick="ResetZoom">Reset zoom</MudMenuItem>
                        <MudDivider />
                        @if(context is not null)
                        {
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit" OnClick="() => EditTaskDialog(context)">Edit Task</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.ColorLens" OnClick="() => MakeTaskBlue(context)">Make it blue</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.ContentCopy" OnClick="() => DuplicateTaskAsync(context)">Duplicate Task</MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Outlined.Delete" IconColor="Color.Error" OnClick="() => DeleteTaskAsync(context)">Delete @context.Name</MudMenuItem>
                        }
                    </TaskContextMenu>

                </MudGanttChart>
            </MudPaper>

        </MudStack>
    </MudPaper>

    <!-- Task Details Card (shown when task is selected) -->
    <HomeTaskDetailsCard Task="_selectedTask"
                         Tasks="_tasks"
                         ReadOnly="_readOnly"
                         IsBusy="_isBusy"
                         OnSave="SaveSelectedTaskAsync"
                         OnClose="CloseTaskDetails" />

    <HomeStatisticsPanel Tasks="_tasks" />

</MudContainer>

